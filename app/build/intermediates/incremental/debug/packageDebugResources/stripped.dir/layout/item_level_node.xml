<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="24dp"
    android:paddingBottom="24dp">

    <!-- the bias is adjusted dynamically via layout params to create zigzag -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/nodeCard"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:cardCornerRadius="40dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/levelNumberText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="28sp"
            android:textStyle="bold"
            tools:text="1" />
            
    </com.google.android.material.card.MaterialCardView>

    <ImageView
        android:id="@+id/lockIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_secure"
        app:tint="#444444"
        app:layout_constraintEnd_toEndOf="@id/nodeCard"
        app:layout_constraintBottom_toBottomOf="@id/nodeCard"
        android:layout_marginBottom="4dp"
        android:layout_marginEnd="4dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
